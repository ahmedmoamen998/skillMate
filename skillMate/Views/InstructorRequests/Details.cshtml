@model SkillMate.Models.InstructorRequest

@{
    ViewData["Title"] = "Request Details";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <span class="status-badge @Model.Status.ToLower() mb-3">@Model.Status</span>

                <h2 class="fw-bold mb-4">@Model.SkillName</h2>

                <div class="list-group list-group-flush mb-4">
                    <div class="list-group-item px-0"><strong>Student:</strong> @Model.Student?.FullName</div>
                    <div class="list-group-item px-0"><strong>Category:</strong> @Model.Category</div>
                    <div class="list-group-item px-0"><strong>Level:</strong> @Model.Level</div>
                    <div class="list-group-item px-0"><strong>Available Time:</strong> @Model.AvailableTime</div>
                    <div class="list-group-item px-0"><strong>Max Students:</strong> @Model.MaxStudents</div>
                    <div class="list-group-item px-0"><strong>Contact Info:</strong> @Model.ContactInfo</div>
                    <div class="list-group-item px-0"><strong>Submitted Date:</strong> @Model.SubmittedDate.ToShortDateString()</div>
                </div>

                <h3 class="h5 fw-bold">Description</h3>
                <p class="text-muted">@Model.Description</p>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <a asp-action="Index" class="btn btn-light">Back</a>

                    @if (Model.Status == "Pending")
                    {
                        <a asp-action="Approve" asp-route-id="@Model.Id" class="btn btn-primary">Approve</a>
                        <a asp-action="Reject" asp-route-id="@Model.Id" class="btn btn-danger">Reject</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
