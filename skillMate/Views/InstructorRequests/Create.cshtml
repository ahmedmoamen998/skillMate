@model SkillMate.Models.InstructorRequest

@{
    ViewData["Title"] = "Apply as Instructor";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <h2 class="fw-bold mb-2">Apply as Student Instructor</h2>
                <p class="text-muted mb-4">Submit your skill request. Admin will review it before publishing.</p>

                <form asp-action="Create" method="post" onsubmit="return validateRequestForm()">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Skill Name</label>
                        <input name="SkillName" class="form-control" id="SkillName" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category</label>
                        <select name="Category" class="form-select" id="Category">
                            <option value="">Select Category</option>
                            <option value="Programming">Programming</option>
                            <option value="Design">Design</option>
                            <option value="Language">Language</option>
                            <option value="Business">Business</option>
                            <option value="Soft Skills">Soft Skills</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Level</label>
                        <select name="Level" class="form-select" id="Level">
                            <option value="">Select Level</option>
                            <option value="Beginner">Beginner</option>
                            <option value="Intermediate">Intermediate</option>
                            <option value="Advanced">Advanced</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Available Time</label>
                        <input name="AvailableTime" class="form-control" id="AvailableTime" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Max Students</label>
                        <input name="MaxStudents" class="form-control" id="MaxStudents" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Contact Info</label>
                        <input name="ContactInfo" class="form-control" id="ContactInfo" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="Description" class="form-control" id="Description" rows="5"></textarea>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-primary">Submit Request</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-light">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
