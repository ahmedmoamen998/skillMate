@model IEnumerable<SkillMate.Models.InstructorRequest>

@{
    ViewData["Title"] = "Instructor Requests";
}

<div class="mb-4">
    <h2 class="fw-bold mb-1">Instructor Requests</h2>
    <p class="text-muted mb-0">Review, approve, or reject student instructor requests.</p>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Student</th>
                        <th>Skill</th>
                        <th>Category</th>
                        <th>Level</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Student?.FullName</td>
                            <td>@item.SkillName</td>
                            <td>@item.Category</td>
                            <td>@item.Level</td>
                            <td>
                                <span class="status-badge @item.Status.ToLower()">
                                    @item.Status
                                </span>
                            </td>
                            <td>@item.SubmittedDate.ToShortDateString()</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-light btn-sm">Details</a>

                                    @if (item.Status == "Pending")
                                    {
                                        <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-primary btn-sm">Approve</a>
                                        <a asp-action="Reject" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Reject</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
