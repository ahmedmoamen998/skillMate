@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="hero admin-hero">
    <div>
        <h1>Welcome Admin</h1>
        <p>Manage skill classes, instructor requests, and student registrations.</p>

        <div class="hero-actions">
            <a asp-controller="SkillClasses" asp-action="Index" class="btn-primary">Manage Skills</a>
            <a asp-controller="SkillClasses" asp-action="Create" class="btn-secondary">Add New Skill</a>
            <a asp-controller="InstructorRequests" asp-action="Index" class="btn-light">Instructor Requests</a>
        </div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="dashboard-card">
        <h3>Total Skills</h3>
        <p>@ViewBag.TotalSkills</p>
    </div>

    <div class="dashboard-card">
        <h3>Pending Requests</h3>
        <p>@ViewBag.PendingRequests</p>
    </div>

    <div class="dashboard-card">
        <h3>Total Registrations</h3>
        <p>@ViewBag.TotalRegisteredStudents</p>
    </div>
</div>