@model SkillMate.Models.SkillClass

@{
    ViewData["Title"] = "Delete Skill";
}

<div class="details-card">
    <h2>Delete Skill Class</h2>

    <p>Are you sure you want to delete this skill class?</p>

    <div class="delete-box">
        <h3>@Model.SkillName</h3>
        <p><strong>Instructor:</strong> @Model.InstructorName</p>
        <p><strong>Category:</strong> @Model.Category</p>
        <p><strong>Level:</strong> @Model.Level</p>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn-danger">Delete</button>
        <a asp-action="Index" class="btn-light">Cancel</a>
    </form>
</div>