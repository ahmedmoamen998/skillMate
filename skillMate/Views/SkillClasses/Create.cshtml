@model SkillMate.Models.SkillClass

@{
    ViewData["Title"] = "Create Skill";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <h2 class="fw-bold mb-4">Add New Skill Class</h2>

                <form asp-action="Create" method="post" onsubmit="return validateSkillForm()">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    @await Html.PartialAsync("_SkillClassForm", Model)

                    <div class="d-flex gap-2 flex-wrap mt-4">
                        <button type="submit" class="btn btn-primary">Create</button>
                        <a asp-action="Index" class="btn btn-light">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
