@model IEnumerable<SkillMate.Models.SkillClass>

@{
    ViewData["Title"] = "Skill Classes";
}

<div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
    <div>
        <h2 class="fw-bold mb-1">Skill Classes</h2>
        <p class="text-muted mb-0">Browse available student-led skill classes.</p>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">Add New Skill</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success rounded-3">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger rounded-3">@TempData["Error"]</div>
}

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-lg-6">
                <input type="text" class="form-control" id="skillSearch" placeholder="Search by skill or instructor..." onkeyup="filterSkills()" />
            </div>

            <div class="col-md-6 col-lg-3">
                <select class="form-select" id="categoryFilter" onchange="filterSkills()">
                    <option value="">All Categories</option>
                    <option value="Programming">Programming</option>
                    <option value="Design">Design</option>
                    <option value="Language">Language</option>
                    <option value="Business">Business</option>
                    <option value="Soft Skills">Soft Skills</option>
                </select>
            </div>

            <div class="col-md-6 col-lg-3">
                <select class="form-select" id="levelFilter" onchange="filterSkills()">
                    <option value="">All Levels</option>
                    <option value="Beginner">Beginner</option>
                    <option value="Intermediate">Intermediate</option>
                    <option value="Advanced">Advanced</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        int registeredStudents = item.StudentRegistrations != null
        ? item.StudentRegistrations.Count
        : 0;

        <div class="col-md-6 col-xl-4 skill-card"
             data-skill="@item.SkillName.ToLower()"
             data-instructor="@item.InstructorName.ToLower()"
             data-category="@item.Category"
             data-level="@item.Level">

            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <span class="badge text-bg-primary rounded-pill mb-3">@item.Category</span>

                    <h3 class="h5 fw-bold">@item.SkillName</h3>

                    <p class="mb-1"><strong>Instructor:</strong> @item.InstructorName</p>
                    <p class="mb-1"><strong>Level:</strong> @item.Level</p>
                    <p class="mb-1"><strong>Available:</strong> @item.AvailableTime</p>
                    <p class="mb-3"><strong>Students:</strong> @registeredStudents / @item.MaxStudents</p>

                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-light btn-sm">Details</a>

                        @if (User.IsInRole("User"))
                        {
                            if (registeredStudents >= item.MaxStudents)
                            {
                                <button class="btn btn-secondary btn-sm" disabled>Full</button>
                            }
                            else
                            {
                                <form asp-action="Join" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-primary btn-sm">Join</button>
                                </form>
                            }
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success btn-sm">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete this skill class?');">
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
