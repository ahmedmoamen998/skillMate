@model SkillMate.Models.SkillClass

@{
    ViewData["Title"] = "Skill Details";

    int registeredStudents = Model.StudentRegistrations != null
        ? Model.StudentRegistrations.Count
        : 0;
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <span class="badge text-bg-primary rounded-pill mb-3">@Model.Category</span>

                <h2 class="fw-bold mb-4">@Model.SkillName</h2>

                <div class="list-group list-group-flush mb-4">
                    <div class="list-group-item px-0"><strong>Instructor:</strong> @Model.InstructorName</div>
                    <div class="list-group-item px-0"><strong>Level:</strong> @Model.Level</div>
                    <div class="list-group-item px-0"><strong>Available Time:</strong> @Model.AvailableTime</div>
                    <div class="list-group-item px-0"><strong>Contact Info:</strong> @Model.ContactInfo</div>
                    <div class="list-group-item px-0"><strong>Students:</strong> @registeredStudents / @Model.MaxStudents</div>
                </div>

                <h3 class="h5 fw-bold">Description</h3>
                <p class="text-muted">@Model.Description</p>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <a asp-action="Index" class="btn btn-light">Back</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-success">Edit</a>
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Are you sure you want to delete this skill class?');">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    }

                    @if (User.IsInRole("User"))
                    {
                        if (registeredStudents >= Model.MaxStudents)
                        {
                            <button class="btn btn-secondary" disabled>Full</button>
                        }
                        else
                        {
                            <form asp-action="Join" asp-route-id="@Model.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-primary">Join</button>
                            </form>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
